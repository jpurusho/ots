{
  "name": "ots",
  "private": true,
  "version": "3.5.4",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"ELECTRON=1 npm run dev\" \"wait-on tcp:5173 && tsc -p tsconfig.main.json && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -b && vite build",
    "dist": "npm run build:electron && electron-builder build --mac --publish never",
    "release": "npm run build:electron && electron-builder build --mac --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}
