{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(npm run *)",
      "Bash(cargo build)",
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(python3 scripts/token_cost.py *)",
      "Bash(pytest *)",
      "Bash(node *)",
      "Bash(chmod +x *)",
      "Agent(*)",
      "Skill(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskList(*)",
      "TaskGet(*)",
      "TaskStop(*)",
      "AskUserQuestion(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(* | xargs rm *)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(trash *)",
      "Bash(shred *)",
      "Bash(dd if=/dev/zero *)",
      "Bash(> /dev/*)",
      "Bash(truncate -s 0 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard HEAD~*)",
      "Bash(git clean -f*)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(cargo update *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)"
    ]
  },
  "hooks": {
    "SessionEnd": []
  }
}
